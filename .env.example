# Copy to .env and adjust as needed. All values have sensible defaults.

# Database — point this at PostgreSQL for production.
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/product_verification

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_HOURS=24

# Azure OpenAI (optional — enables AI image date extraction when set)
# AZURE_OPENAI_API_KEY=your-azure-openai-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview  # 2024-08-01-preview+ required for structured outputs
# GPT_DEPLOYMENT=gpt-4o

# App
DEBUG=False
UPLOAD_DIR=uploads
